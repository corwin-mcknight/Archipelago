{
    "build": {
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        "source=vscode-extensions-${devcontainerId},target=/root/.vscode-server/extensions,type=volume",
        "source=vscode-server-data-${devcontainerId},target=/root/.vscode-server/data,type=volume"
    ],
    "forwardPorts": [7878],
    "customizations": {
        "vscode": {
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "xaver.clang-format",
                "twxs.cmake",
                "ms-vscode.cpptools",
                "ms-vscode.makefile-tools"
            ]
        }
    }
}
