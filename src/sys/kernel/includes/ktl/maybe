#pragma once

#include <kernel/panic.h>
#include <ktl/fmt>
#include <ktl/string_view>
#include <ktl/type_traits>
#include <ktl/utility>

namespace ktl {

template <typename T> class maybe;

struct nothing_t {
    explicit constexpr nothing_t(int) {}
    template <typename T> operator maybe<T>() const { return maybe<T>(); }
};

inline constexpr nothing_t nothing{0xBADC0DE};

template <typename T> class [[nodiscard]] maybe {
   private:
    bool m_has_value;
    T m_value;

   public:
    maybe() : m_has_value(false), m_value{} {}
    maybe(nothing_t) : m_has_value(false), m_value{} {}
    maybe(const T& value) : m_has_value(true), m_value(value) {}
    maybe(T&& value) : m_has_value(true), m_value(ktl::move(value)) {}

    bool has_value() const { return m_has_value; }
    bool has_value() { return m_has_value; }
    explicit operator bool() const { return m_has_value; }

    // Accessing the value of an empty maybe is a kernel bug and panics, mirroring Result::unwrap.
    T& value() {
        if (!m_has_value) { panic("maybe::value on empty maybe"); }
        return m_value;
    }
    const T& value() const {
        if (!m_has_value) { panic("maybe::value on empty maybe"); }
        return m_value;
    }

    // Like value(), but panics with a caller-supplied diagnosis, mirroring Result::expect.
    T& expect(const char* error_message) {
        if (!m_has_value) { panic(error_message); }
        return m_value;
    }
    const T& expect(const char* error_message) const {
        if (!m_has_value) { panic(error_message); }
        return m_value;
    }

    void reset() {
        m_has_value = false;
        m_value     = T{};
    }

    /// Moves the value out (leaving this maybe empty), or returns nothing if already empty.
    maybe<T> take() {
        if (!m_has_value) { return nothing; }
        maybe<T> out(ktl::move(m_value));
        reset();
        return out;
    }

    T& operator*() {
        if (!m_has_value) { panic("maybe::operator* on empty maybe"); }
        return m_value;
    }
    const T& operator*() const {
        if (!m_has_value) { panic("maybe::operator* on empty maybe"); }
        return m_value;
    }

    T* operator->() {
        if (!m_has_value) { panic("maybe::operator-> on empty maybe"); }
        return &m_value;
    }
    const T* operator->() const {
        if (!m_has_value) { panic("maybe::operator-> on empty maybe"); }
        return &m_value;
    }

    bool operator==(const maybe<T>& other) const {
        if (m_has_value != other.m_has_value) { return false; }
        if (!m_has_value) { return true; }
        return m_value == other.m_value;
    }

    bool operator!=(const maybe<T>& other) const { return !(*this == other); }

    // Monadic operations

    template <typename U> T value_or(U&& default_value) const {
        if (m_has_value) { return m_value; }
        return static_cast<T>(default_value);
    }

    template <typename F> auto map(F&& func) const -> maybe<decltype(func(m_value))> {
        if (!m_has_value) { return nothing; }
        return maybe<decltype(func(m_value))>(func(m_value));
    }

    /// Flat map
    template <typename F> auto and_then(F&& func) const -> decltype(func(m_value)) {
        if (!m_has_value) { return nothing; }
        return func(m_value);
    }

    template <typename F> maybe<T> or_else(F&& func) const {
        if (m_has_value) { return *this; }
        return func();
    }

    /// Maps the contained value, or returns the default untouched when empty.
    template <typename F, typename U> auto map_or(F&& func, U&& default_value) const -> decltype(func(m_value)) {
        if (!m_has_value) { return static_cast<decltype(func(m_value))>(ktl::forward<U>(default_value)); }
        return func(m_value);
    }

    /// Calls func with the contained value for its side effect (if any), returning the maybe unchanged.
    /// Fills the gap where map cannot take a void-returning function.
    template <typename F> maybe<T>& inspect(F&& func) {
        if (m_has_value) { func(m_value); }
        return *this;
    }
    template <typename F> const maybe<T>& inspect(F&& func) const {
        if (m_has_value) { func(m_value); }
        return *this;
    }

    /// @brief Filters this maybe by predicate, returning the original value or nothing
    /// @tparam F
    /// @param predicate The predicate
    /// @return Original maybe or nothing
    template <typename F> auto filter(F&& predicate) const -> maybe<T> {
        if (!m_has_value) { return nothing; }
        if (predicate(m_value)) { return *this; }
        return nothing;
    }
};

/// Reference specialization: a non-owning optional reference, stored internally as a pointer.
/// Engaged implies valid -- it cannot hold a null reference -- so it replaces both the
/// raw-pointer-as-sentinel idiom and the maybe<T*> double-optional. Unlike the primary template
/// it places no default-constructible or copyable requirement on T and never copies the referent.
template <typename T> class [[nodiscard]] maybe<T&> {
   private:
    T* m_ptr;

   public:
    maybe() : m_ptr(nullptr) {}
    maybe(nothing_t) : m_ptr(nullptr) {}
    maybe(T& ref) : m_ptr(&ref) {}
    maybe(T&&) = delete;  // a temporary would dangle immediately

    bool has_value() const { return m_ptr != nullptr; }
    explicit operator bool() const { return m_ptr != nullptr; }

    T& value() const {
        if (!m_ptr) { panic("maybe::value on empty maybe"); }
        return *m_ptr;
    }

    T& expect(const char* error_message) const {
        if (!m_ptr) { panic(error_message); }
        return *m_ptr;
    }

    T& operator*() const {
        if (!m_ptr) { panic("maybe::operator* on empty maybe"); }
        return *m_ptr;
    }

    T* operator->() const {
        if (!m_ptr) { panic("maybe::operator-> on empty maybe"); }
        return m_ptr;
    }

    T& value_or(T& fallback) const { return m_ptr ? *m_ptr : fallback; }

    /// Escape hatch for raw-pointer interop.
    T* ptr_or(T* fallback = nullptr) const { return m_ptr ? m_ptr : fallback; }

    void reset() { m_ptr = nullptr; }

    // Monadic operations

    template <typename F> auto map(F&& func) const -> maybe<decltype(func(*m_ptr))> {
        if (!m_ptr) { return nothing; }
        return maybe<decltype(func(*m_ptr))>(func(*m_ptr));
    }

    /// Flat map
    template <typename F> auto and_then(F&& func) const -> decltype(func(*m_ptr)) {
        if (!m_ptr) { return nothing; }
        return func(*m_ptr);
    }

    template <typename F> maybe<T&> or_else(F&& func) const {
        if (m_ptr) { return *this; }
        return func();
    }

    template <typename F, typename U> auto map_or(F&& func, U&& default_value) const -> decltype(func(*m_ptr)) {
        if (!m_ptr) { return static_cast<decltype(func(*m_ptr))>(ktl::forward<U>(default_value)); }
        return func(*m_ptr);
    }

    template <typename F> maybe<T&> filter(F&& predicate) const {
        if (!m_ptr) { return nothing; }
        if (predicate(*m_ptr)) { return *this; }
        return nothing;
    }

    template <typename F> const maybe<T&>& inspect(F&& func) const {
        if (m_ptr) { func(*m_ptr); }
        return *this;
    }
};

/// Bridges a nullable raw pointer (C ABI, bootloader/vendor structs) into the maybe world.
template <typename T> maybe<T&> from_ptr(T* ptr) {
    if (ptr == nullptr) { return nothing; }
    return maybe<T&>(*ptr);
}

template <typename T, typename F> void filter(maybe<T>* arr, int count, F&& func) {
    for (int i = 0; i < count; i++) { arr[i] = arr[i].filter(func); }
}

};  // namespace ktl

template <> struct ktl::format::kfmt_printer<ktl::nothing_t> {
    static void print(format_args args, char* buffer, size_t buffer_max, size_t& index, ktl::nothing_t) {
        args.zero_padded = false;
        format_args::print_string(args, buffer, buffer_max, index, "<<ktl::nothing_t>>");
    }
};

template <typename T> struct ktl::format::kfmt_printer<ktl::maybe<T>> {
    static void print(format_args args, char* buffer, size_t buffer_max, size_t& index, const ktl::maybe<T>& arg) {
        if (arg.has_value()) {
            kfmt_printer<T>::print(args, buffer, buffer_max, index, arg.value());
        } else {
            kfmt_printer<ktl::nothing_t>::print(args, buffer, buffer_max, index, ktl::nothing);
        }
    }
};