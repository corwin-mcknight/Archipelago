#pragma once

#include <stdlib.h>

#include <ktl/fmt_type>

namespace ktl {
namespace format {

// Unified integer printer macro. SIGNED: 0 for unsigned, 1 for signed.
#define KFMT_INT_PRINTER_IMPL(KFMT_TYPE, MAX_BUFFER, SIGNED)                                  \
    template <>                                                                                \
    struct kfmt_printer<KFMT_TYPE> {                                                           \
        static void print(format_args args, char* buffer, size_t buffer_max, size_t& index,    \
                          KFMT_TYPE value) {                                                   \
            char number_temp[MAX_BUFFER];                                                      \
            memset(number_temp, 0, MAX_BUFFER);                                                \
            if constexpr (SIGNED) {                                                            \
                if (value < 0) {                                                               \
                    buffer[index++] = '-';                                                     \
                    value = static_cast<KFMT_TYPE>(-value);                                    \
                }                                                                              \
            }                                                                                  \
            unsigned int base;                                                                 \
            switch (args.specifier) {                                                          \
                case 'h':                                                                      \
                case 'x':                                                                      \
                case 'p': base = 16; break;                                                    \
                case 'd': base = 10; break;                                                    \
                case 'o': base = 8; break;                                                     \
                case 'b': base = 2; break;                                                     \
                default: base = 10; break;                                                     \
            }                                                                                  \
            itoa((unsigned long long)value, number_temp, base);                                \
            format_args::print_string(args, buffer, buffer_max, index, number_temp);           \
        }                                                                                      \
    };

KFMT_INT_PRINTER_IMPL(short, 18, 1);
KFMT_INT_PRINTER_IMPL(unsigned short, 18, 0);
KFMT_INT_PRINTER_IMPL(int, 34, 1);
KFMT_INT_PRINTER_IMPL(unsigned int, 34, 0);
KFMT_INT_PRINTER_IMPL(long, 66, 1);
KFMT_INT_PRINTER_IMPL(unsigned long, 66, 0);
KFMT_INT_PRINTER_IMPL(long long, 66, 1);
KFMT_INT_PRINTER_IMPL(unsigned long long, 66, 0);

#undef KFMT_INT_PRINTER_IMPL

template <typename IntType>
static void print_char_or_int(format_args args, char* buffer, size_t buffer_max, size_t& index,
                              auto raw_value) {
    if (args.specifier == 'c') {
        buffer[index++] = static_cast<char>(raw_value);
    } else {
        kfmt_printer<IntType>::print(args, buffer, buffer_max, index, static_cast<IntType>(raw_value));
    }
}

template <>
struct kfmt_printer<char> {
    static void print(format_args args, char* buffer, size_t buffer_max, size_t& index, char value) {
        print_char_or_int<int>(args, buffer, buffer_max, index, value);
    }
};

template <>
struct kfmt_printer<unsigned char> {
    static void print(format_args args, char* buffer, size_t buffer_max, size_t& index, unsigned char value) {
        print_char_or_int<unsigned int>(args, buffer, buffer_max, index, value);
    }
};

template <>
struct kfmt_printer<const char*> {
    static void print(format_args args, char* buffer, size_t buffer_max, size_t& index, const char* value) {
        args.zero_padded = false;
        format_args::print_string(args, buffer, buffer_max, index, value);
    }
};

}  // namespace format
}  // namespace ktl
