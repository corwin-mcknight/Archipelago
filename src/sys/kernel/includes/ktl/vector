#pragma once

#include <stddef.h>

#include <ktl/maybe>
#include <ktl/type_traits>
#include <ktl/utility>

namespace ktl {

template <typename T> class vector {
   public:
    template <typename Value> class iterator_impl {
       public:
        using difference_type     = ptrdiff_t;
        using value_type          = typename ktl::remove_const<Value>::type;
        using pointer             = Value*;
        using reference           = Value&;

        constexpr iterator_impl() = default;
        constexpr explicit iterator_impl(pointer ptr) : m_ptr(ptr) {}
        constexpr iterator_impl(const iterator_impl&)            = default;
        constexpr iterator_impl& operator=(const iterator_impl&) = default;

        template <typename Other> constexpr iterator_impl(const iterator_impl<Other>& other) : m_ptr(other.m_ptr) {}

        template <typename Other> constexpr iterator_impl& operator=(const iterator_impl<Other>& other) {
            m_ptr = other.m_ptr;
            return *this;
        }

        constexpr reference operator*() const { return *m_ptr; }
        constexpr pointer operator->() const { return m_ptr; }

        constexpr iterator_impl& operator++() {
            ++m_ptr;
            return *this;
        }

        constexpr iterator_impl operator++(int) {
            iterator_impl tmp(*this);
            ++(*this);
            return tmp;
        }

        constexpr iterator_impl& operator--() {
            --m_ptr;
            return *this;
        }

        constexpr iterator_impl operator--(int) {
            iterator_impl tmp(*this);
            --(*this);
            return tmp;
        }

        constexpr iterator_impl& operator+=(difference_type n) {
            m_ptr += n;
            return *this;
        }

        constexpr iterator_impl operator+(difference_type n) const {
            iterator_impl tmp(*this);
            tmp += n;
            return tmp;
        }

        friend constexpr iterator_impl operator+(difference_type n, iterator_impl it) { return it + n; }

        constexpr iterator_impl& operator-=(difference_type n) {
            m_ptr -= n;
            return *this;
        }

        constexpr iterator_impl operator-(difference_type n) const {
            iterator_impl tmp(*this);
            tmp -= n;
            return tmp;
        }

        template <typename Other> constexpr difference_type operator-(const iterator_impl<Other>& other) const {
            return m_ptr - other.m_ptr;
        }

        constexpr reference operator[](difference_type n) const { return *(*this + n); }

        template <typename Other> constexpr bool operator==(const iterator_impl<Other>& other) const {
            return m_ptr == other.m_ptr;
        }

        template <typename Other> constexpr bool operator!=(const iterator_impl<Other>& other) const {
            return !(*this == other);
        }

        template <typename Other> constexpr bool operator<(const iterator_impl<Other>& other) const {
            return m_ptr < other.m_ptr;
        }

        template <typename Other> constexpr bool operator>(const iterator_impl<Other>& other) const {
            return other < *this;
        }

        template <typename Other> constexpr bool operator<=(const iterator_impl<Other>& other) const {
            return !(other < *this);
        }

        template <typename Other> constexpr bool operator>=(const iterator_impl<Other>& other) const {
            return !(*this < other);
        }

        constexpr pointer get() const { return m_ptr; }

       private:
        template <typename> friend class iterator_impl;

        pointer m_ptr = nullptr;
    };

    using iterator       = iterator_impl<T>;
    using const_iterator = iterator_impl<const T>;

    vector()             = default;

    ~vector() { delete[] m_data; }

    vector(const vector&)            = delete;
    vector& operator=(const vector&) = delete;

    vector(vector&& other) noexcept { move_from(ktl::move(other)); }

    vector& operator=(vector&& other) noexcept {
        if (this != &other) {
            delete[] m_data;
            move_from(ktl::move(other));
        }
        return *this;
    }

    bool push_back(T value) {
        if (!ensure_capacity(m_size + 1)) { return false; }
        m_data[m_size++] = ktl::move(value);
        return true;
    }

    bool emplace_back(T&& value) { return push_back(ktl::move(value)); }

    ktl::maybe<T> pop_back() {
        if (empty()) { return ktl::nothing; }
        T value = ktl::move(m_data[m_size - 1]);
        --m_size;
        return value;
    }

    ktl::maybe<T> front() const {
        if (empty()) { return ktl::nothing; }
        return m_data[0];
    }

    ktl::maybe<T> back() const {
        if (empty()) { return ktl::nothing; }
        return m_data[m_size - 1];
    }

    void clear() { m_size = 0; }

    size_t size() const { return m_size; }
    bool empty() const { return m_size == 0; }
    size_t capacity() const { return m_capacity; }

    bool reserve(size_t new_capacity) {
        if (new_capacity <= m_capacity) { return true; }
        if (new_capacity < m_size) { new_capacity = m_size; }
        return reallocate(new_capacity);
    }

    T& operator[](size_t index) { return m_data[index]; }
    const T& operator[](size_t index) const { return m_data[index]; }

    ktl::maybe<T> at(size_t index) const {
        if (index >= m_size) { return ktl::nothing; }
        return m_data[index];
    }

    T* data() { return m_data; }
    const T* data() const { return m_data; }

    iterator begin() { return iterator(m_data); }
    iterator end() { return iterator(m_data ? m_data + m_size : nullptr); }
    const_iterator begin() const { return const_iterator(m_data); }
    const_iterator end() const { return const_iterator(m_data ? m_data + m_size : nullptr); }
    const_iterator cbegin() const { return begin(); }
    const_iterator cend() const { return end(); }

   private:
    static constexpr size_t k_initial_capacity = 4;

    void move_from(vector&& other) noexcept {
        m_data           = other.m_data;
        m_size           = other.m_size;
        m_capacity       = other.m_capacity;

        other.m_data     = nullptr;
        other.m_size     = 0;
        other.m_capacity = 0;
    }

    bool ensure_capacity(size_t required) {
        if (required <= m_capacity) { return true; }

        size_t new_capacity = m_capacity == 0 ? k_initial_capacity : m_capacity;
        while (new_capacity < required) { new_capacity *= 2; }
        return reallocate(new_capacity);
    }

    bool reallocate(size_t new_capacity) {
        T* new_data = new T[new_capacity];
        if (new_data == nullptr) { return false; }

        for (size_t i = 0; i < m_size; ++i) { new_data[i] = ktl::move(m_data[i]); }

        delete[] m_data;

        m_data     = new_data;
        m_capacity = new_capacity;
        return true;
    }

    T* m_data         = nullptr;
    size_t m_size     = 0;
    size_t m_capacity = 0;
};

}  // namespace ktl
