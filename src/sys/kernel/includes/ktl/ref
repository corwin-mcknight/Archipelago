#pragma once

#include <stddef.h>
#include <stdint.h>

#include <ktl/atomic>
#include <ktl/utility>

namespace ktl {

namespace detail {

struct ref_control_block_base {
    atomic<uint32_t> ref_count{1};
    virtual void destroy()            = 0;
    virtual ~ref_control_block_base() = default;
};

template <typename T> struct ref_control_block : ref_control_block_base {
    T* ptr;
    explicit ref_control_block(T* p) : ptr(p) {}
    void destroy() override { delete ptr; }
};

}  // namespace detail

template <typename T> class ref {
   public:
    ref() : m_ptr(nullptr), m_block(nullptr) {}

    ref(const ref& other) : m_ptr(other.m_ptr), m_block(other.m_block) {
        if (m_block) { m_block->ref_count.fetch_add(1, memory_order::relaxed); }
    }

    ref(ref&& other) noexcept : m_ptr(other.m_ptr), m_block(other.m_block) {
        other.m_ptr   = nullptr;
        other.m_block = nullptr;
    }

    // Converting constructor: ref<Derived> -> ref<Base>
    template <typename U> ref(const ref<U>& other) : m_ptr(other.get()), m_block(other.control_block()) {
        if (m_block) { m_block->ref_count.fetch_add(1, memory_order::relaxed); }
    }

    template <typename U> ref(ref<U>&& other) : m_ptr(other.get()), m_block(other.control_block()) { other.clear(); }

    ref& operator=(const ref& other) {
        if (this == &other) { return *this; }
        release();
        m_ptr   = other.m_ptr;
        m_block = other.m_block;
        if (m_block) { m_block->ref_count.fetch_add(1, memory_order::relaxed); }
        return *this;
    }

    ref& operator=(ref&& other) noexcept {
        if (this == &other) { return *this; }
        release();
        m_ptr         = other.m_ptr;
        m_block       = other.m_block;
        other.m_ptr   = nullptr;
        other.m_block = nullptr;
        return *this;
    }

    ~ref() { release(); }

    T* get() const { return m_ptr; }
    T* operator->() const { return m_ptr; }
    T& operator*() const { return *m_ptr; }
    explicit operator bool() const { return m_ptr != nullptr; }

    void reset() { release(); }

    uint32_t ref_count() const {
        if (!m_block) { return 0; }
        return m_block->ref_count.load(memory_order::relaxed);
    }

    bool operator==(const ref& other) const { return m_block == other.m_block; }
    bool operator!=(const ref& other) const { return m_block != other.m_block; }

    // Internal: used by converting constructors
    detail::ref_control_block_base* control_block() const { return m_block; }
    void clear() {
        m_ptr   = nullptr;
        m_block = nullptr;
    }

   private:
    template <typename U, typename... Args> friend ref<U> make_ref(Args&&...);
    template <typename U, typename V> friend ref<U> static_ref_cast(const ref<V>&);

    ref(T* ptr, detail::ref_control_block_base* block) : m_ptr(ptr), m_block(block) {}

    void release() {
        if (!m_block) { return; }
        uint32_t prev = m_block->ref_count.fetch_sub(1, memory_order::acq_rel);
        if (prev == 1) {
            m_block->destroy();
            delete m_block;
        }
        m_ptr   = nullptr;
        m_block = nullptr;
    }

    T* m_ptr;
    detail::ref_control_block_base* m_block;
};

template <typename T, typename... Args> ref<T> make_ref(Args&&... args) {
    T* obj    = new T(ktl::forward<Args>(args)...);
    auto* blk = new detail::ref_control_block<T>(obj);
    return ref<T>(obj, blk);
}

template <typename T, typename U> ref<T> static_ref_cast(const ref<U>& other) {
    if (!other) { return ref<T>(); }
    auto* block = other.control_block();
    block->ref_count.fetch_add(1, memory_order::relaxed);
    return ref<T>(static_cast<T*>(other.get()), block);
}

}  // namespace ktl
