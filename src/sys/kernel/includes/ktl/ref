#pragma once

#include <stddef.h>
#include <stdint.h>

#include <ktl/atomic>
#include <ktl/utility>

namespace ktl {

namespace detail {

template <typename T>
struct ref_control_block {
    T* ptr;
    atomic<uint32_t> ref_count{1};

    explicit ref_control_block(T* p) : ptr(p) {}
};

}  // namespace detail

template <typename T>
class ref {
   public:
    ref() : m_block(nullptr) {}

    ref(const ref& other) : m_block(other.m_block) {
        if (m_block) { m_block->ref_count.fetch_add(1, memory_order::relaxed); }
    }

    ref(ref&& other) noexcept : m_block(other.m_block) { other.m_block = nullptr; }

    ref& operator=(const ref& other) {
        if (this == &other) { return *this; }
        release();
        m_block = other.m_block;
        if (m_block) { m_block->ref_count.fetch_add(1, memory_order::relaxed); }
        return *this;
    }

    ref& operator=(ref&& other) noexcept {
        if (this == &other) { return *this; }
        release();
        m_block       = other.m_block;
        other.m_block = nullptr;
        return *this;
    }

    ~ref() { release(); }

    T* get() const { return m_block ? m_block->ptr : nullptr; }
    T* operator->() const { return get(); }
    T& operator*() const { return *get(); }
    explicit operator bool() const { return m_block != nullptr; }

    void reset() { release(); }

    uint32_t ref_count() const {
        if (!m_block) { return 0; }
        return m_block->ref_count.load(memory_order::relaxed);
    }

    bool operator==(const ref& other) const { return m_block == other.m_block; }
    bool operator!=(const ref& other) const { return m_block != other.m_block; }

   private:
    template <typename U, typename... Args>
    friend ref<U> make_ref(Args&&...);

    explicit ref(detail::ref_control_block<T>* block) : m_block(block) {}

    void release() {
        if (!m_block) { return; }
        uint32_t prev = m_block->ref_count.fetch_sub(1, memory_order::acq_rel);
        if (prev == 1) {
            delete m_block->ptr;
            delete m_block;
        }
        m_block = nullptr;
    }

    detail::ref_control_block<T>* m_block;
};

template <typename T, typename... Args>
ref<T> make_ref(Args&&... args) {
    T* obj                          = new T(ktl::forward<Args>(args)...);
    auto* block                     = new detail::ref_control_block<T>(obj);
    return ref<T>(block);
}

}  // namespace ktl
