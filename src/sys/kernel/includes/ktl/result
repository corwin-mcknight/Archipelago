#pragma once

#include <ktl/errc>
#include <ktl/utility>
#include <std/new.h>

#include "kernel/panic.h"

namespace ktl {

namespace detail {
/// True when every type is trivially copyable (which implies trivially destructible). Used to make
/// result itself trivially copyable -- and thus register-passable -- for small payloads like errc.
template <typename... Ts>
concept all_trivial = (__is_trivially_copyable(Ts) && ...);
}  // namespace detail

template <typename T, typename E = errc> struct [[nodiscard]] result {
   private:
    union Storage {
        T ok;
        E err;
        Storage() {}
        ~Storage() requires detail::all_trivial<T, E> = default;
        ~Storage() {}
    } value;
    bool m_ok;

    struct ok_tag {};
    struct err_tag {};
    result(ok_tag, T val) : m_ok(true) { new (&value.ok) T(ktl::move(val)); }
    result(err_tag, E val) : m_ok(false) { new (&value.err) E(ktl::move(val)); }

    void destroy() {
        if (m_ok) { value.ok.~T(); }
        else { value.err.~E(); }
    }

    template <typename Src> void construct_from(Src&& other) {
        m_ok = other.m_ok;
        if (m_ok) { new (&value.ok) T(ktl::forward<Src>(other).value.ok); }
        else { new (&value.err) E(ktl::forward<Src>(other).value.err); }
    }

   public:
    // Construction -- use the static ok()/err() factories; no value constructors to avoid ambiguity when T == E.
    static result ok(T val) { return result(ok_tag{}, ktl::move(val)); }
    static result err(E val) { return result(err_tag{}, ktl::move(val)); }

    // Special members: trivial (register-passable) when the payloads are, hand-rolled otherwise.
    ~result() requires detail::all_trivial<T, E> = default;
    ~result() { destroy(); }

    result(const result&) requires detail::all_trivial<T, E> = default;
    result(const result& other) { construct_from(other); }
    result(result&&) requires detail::all_trivial<T, E> = default;
    result(result&& other) noexcept { construct_from(ktl::move(other)); }

    result& operator=(const result&) requires detail::all_trivial<T, E> = default;
    result& operator=(const result& other) {
        if (this != &other) {
            destroy();
            construct_from(other);
        }
        return *this;
    }
    result& operator=(result&&) requires detail::all_trivial<T, E> = default;
    result& operator=(result&& other) noexcept {
        if (this != &other) {
            destroy();
            construct_from(ktl::move(other));
        }
        return *this;
    }

    // Boolean
    bool is_ok() const { return m_ok; }
    bool is_err() const { return !m_ok; }
    explicit operator bool() const { return m_ok; }

    // Extraction
    T expect(const char* error_message) const {
        if (is_err()) { panic(error_message); }
        return value.ok;
    }

    T unwrap() {
        if (is_err()) { panic("result unwrap failed"); }
        return ktl::move(value.ok);
    }

    T unwrap() const {
        if (is_err()) { panic("result unwrap failed"); }
        return value.ok;
    }

    E unwrap_err() const {
        if (!is_err()) { panic("result unwrap_err failed"); }
        return value.err;
    }

    // Operators (!= is synthesized from ==)
    bool operator==(const result& other) const {
        if (m_ok != other.m_ok) { return false; }
        if (m_ok) { return value.ok == other.value.ok; }
        return value.err == other.value.err;
    }
};

/// Unit-value result: a fallible operation with no success payload. The ok arm carries nothing;
/// only the error is stored. Mirrors the primary template's API where extraction makes sense.
template <typename E> struct [[nodiscard]] result<void, E> {
   private:
    union Storage {
        E err;
        Storage() {}
        ~Storage() requires detail::all_trivial<E> = default;
        ~Storage() {}
    } value;
    bool m_ok;

    struct ok_tag {};
    struct err_tag {};
    result(ok_tag) : m_ok(true) {}
    result(err_tag, E val) : m_ok(false) { new (&value.err) E(ktl::move(val)); }

    void destroy() {
        if (!m_ok) { value.err.~E(); }
    }

    template <typename Src> void construct_from(Src&& other) {
        m_ok = other.m_ok;
        if (!m_ok) { new (&value.err) E(ktl::forward<Src>(other).value.err); }
    }

   public:
    static result ok() { return result(ok_tag{}); }
    static result err(E val) { return result(err_tag{}, ktl::move(val)); }

    ~result() requires detail::all_trivial<E> = default;
    ~result() { destroy(); }

    result(const result&) requires detail::all_trivial<E> = default;
    result(const result& other) { construct_from(other); }
    result(result&&) requires detail::all_trivial<E> = default;
    result(result&& other) noexcept { construct_from(ktl::move(other)); }

    result& operator=(const result&) requires detail::all_trivial<E> = default;
    result& operator=(const result& other) {
        if (this != &other) {
            destroy();
            construct_from(other);
        }
        return *this;
    }
    result& operator=(result&&) requires detail::all_trivial<E> = default;
    result& operator=(result&& other) noexcept {
        if (this != &other) {
            destroy();
            construct_from(ktl::move(other));
        }
        return *this;
    }

    // Boolean
    bool is_ok() const { return m_ok; }
    bool is_err() const { return !m_ok; }
    explicit operator bool() const { return m_ok; }

    // Extraction
    void expect(const char* error_message) const {
        if (is_err()) { panic(error_message); }
    }

    void unwrap() const {
        if (is_err()) { panic("result unwrap failed"); }
    }

    E unwrap_err() const {
        if (!is_err()) { panic("result unwrap_err failed"); }
        return value.err;
    }

    // Operators (!= is synthesized from ==)
    bool operator==(const result& other) const {
        if (m_ok != other.m_ok) { return false; }
        return m_ok || value.err == other.value.err;
    }
};

/// Error carrier: converts implicitly into any result whose error type is constructible from E.
/// Lets `return ktl::err(code);` work without spelling the enclosing result type.
template <typename E> struct err_carrier {
    E error;
    template <typename T2, typename E2> operator result<T2, E2>() const { return result<T2, E2>::err(E2(error)); }
};

template <typename E> err_carrier<E> err(E error) { return err_carrier<E>{ktl::move(error)}; }

}  // namespace ktl
